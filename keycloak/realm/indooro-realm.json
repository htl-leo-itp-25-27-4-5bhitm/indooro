{
  "realm": "indooro",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      { "name": "admin" },
      { "name": "region-manager" },
      { "name": "store-manager" }
    ]
  },
  "clients": [
    {
      "clientId": "indooro-admin-web",
      "name": "Indooro Admin Web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "indooro-admin-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8080/*",
        "https://it220209.cloud.htl-leonding.ac.at/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "https://it220209.cloud.htl-leonding.ac.at"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8080/*##https://it220209.cloud.htl-leonding.ac.at/*"
      }
    }
  ],
  "users": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "username": "indooro-admin",
      "email": "admin@indooro.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    },
    {
      "id": "22222222-2222-2222-2222-222222222222",
      "username": "indooro-region",
      "email": "region@indooro.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "region",
          "temporary": false
        }
      ],
      "realmRoles": ["region-manager"]
    },
    {
      "id": "33333333-3333-3333-3333-333333333333",
      "username": "indooro-store",
      "email": "store@indooro.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "store",
          "temporary": false
        }
      ],
      "realmRoles": ["store-manager"]
    }
  ]
}
