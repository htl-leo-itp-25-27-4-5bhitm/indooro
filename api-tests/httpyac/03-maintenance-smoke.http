/*
# Indooro Maintenance / Operator API Smoke Tests

These endpoints are intentionally treated as smoke tests. Operator writes run
with the admin bearer token so protected maintenance routes do not fall back to
the browser login flow.
*/

@baseUrl={{BASE_URL}}

###
# Backend health smoke
GET {{baseUrl}}/api/admin/health
Accept: application/json
Authorization: Bearer {{$global.adminToken}}

?? status == 200
?? body status == UP

###
# Product index create is an authenticated operator smoke.
# Note: OpenSpec expects an explicit failure if the index already exists, while
# the current service logs and swallows that condition. Keep this as smoke until
# the product decision is resolved.
POST {{baseUrl}}/api/admin/index/create
Accept: application/json
Authorization: Bearer {{$global.adminToken}}

?? status startsWith 20
?? header content-type includes json

###
# Product bulk import smoke
POST {{baseUrl}}/api/products/bulk
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{$global.adminToken}}

[
  {
    "id": {{TEST_PRODUCT_ID}},
    "name": "{{TEST_PRODUCT_NAME}}",
    "price": {{TEST_PRODUCT_PRICE}},
    "layoutCode": "{{TEST_PRODUCT_LAYOUT_CODE}}",
    "storeId": "{{ACTIVE_STORE_ID}}"
  }
]

?? status startsWith 20
?? header content-type includes json

###
# Product single write smoke
POST {{baseUrl}}/api/products
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{$global.adminToken}}

{
  "id": {{TEST_PRODUCT_ID}},
  "name": "{{TEST_PRODUCT_NAME}}",
  "price": {{TEST_PRODUCT_PRICE}},
  "layoutCode": "{{TEST_PRODUCT_LAYOUT_CODE}}",
  "storeId": "{{ACTIVE_STORE_ID}}"
}

?? status startsWith 20
?? header content-type includes json

###
# Anonymous category bulk import is rejected
POST {{baseUrl}}/api/categories/bulk
Content-Type: application/json
Accept: application/json

[
  {
    "categoryCode": {{TEST_CATEGORY_CODE}},
    "categoryName": "{{TEST_CATEGORY_NAME}}"
  }
]

?? status matches ^(302|401|403)$

###
# Store managers cannot run category bulk imports
POST {{baseUrl}}/api/categories/bulk
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{$global.storeToken}}

[
  {
    "categoryCode": {{TEST_CATEGORY_CODE}},
    "categoryName": "{{TEST_CATEGORY_NAME}}"
  }
]

?? status == 403

###
# Category bulk import smoke
POST {{baseUrl}}/api/categories/bulk
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{$global.adminToken}}

[
  {
    "categoryCode": {{TEST_CATEGORY_CODE}},
    "categoryName": "{{TEST_CATEGORY_NAME}}"
  }
]

?? status startsWith 20
?? header content-type includes json

###
# PDF export smoke
POST {{baseUrl}}/api/export/pdf
Content-Type: application/json
Accept: application/pdf
Authorization: Bearer {{$global.adminToken}}

[
  {
    "id": {{TEST_PRODUCT_ID}},
    "name": "{{TEST_PRODUCT_NAME}}",
    "price": {{TEST_PRODUCT_PRICE}},
    "layoutCode": "{{TEST_PRODUCT_LAYOUT_CODE}}"
  }
]

?? status startsWith 20
?? header content-type includes pdf
